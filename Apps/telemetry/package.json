{
  "name": "@tartware/telemetry",
  "version": "0.1.0",
  "description": "Shared OpenTelemetry utilities for Tartware services",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths --config-file ../../.swcrc -q && tsc --project tsconfig.json --emitDeclarationOnly",
    "lint": "eslint --ext .ts src",
    "lint:fix": "eslint --ext .ts src --fix",
    "biome": "biome check src",
    "biome:fix": "biome format src --write",
    "knip": "knip --tsConfig tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist dist-tests *.tsbuildinfo",
    "build:tests": "tsc --project tsconfig.tests.json",
    "test": "npm run build:tests && node --test dist-tests/tests/*.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.52.1",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.52.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/resources": "^1.25.1",
    "@opentelemetry/sdk-logs": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fastify": "^5.6.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
