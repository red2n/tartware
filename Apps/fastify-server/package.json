{
  "name": "@tartware/fastify-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared Fastify server builder for Tartware services",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./swagger": {
      "types": "./dist/swagger.d.ts",
      "import": "./dist/swagger.js"
    },
    "./registry-client": {
      "types": "./dist/registry-client.d.ts",
      "import": "./dist/registry-client.js"
    }
  },
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths --config-file ../../.swcrc -q && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "echo 'lint skipped'",
    "biome": "echo 'biome skipped'",
    "knip": "echo 'knip skipped'",
    "test": "echo 'test skipped'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@tartware/config": "workspace:*",
    "@tartware/telemetry": "workspace:*",
    "fastify": "^5.2.0",
    "fastify-plugin": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
