{
  "name": "@tartware/command-consumer-utils",
  "version": "0.1.0",
  "description": "Shared command center consumer helpers",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lifecycle": {
      "types": "./dist/consumer-lifecycle.d.ts",
      "import": "./dist/consumer-lifecycle.js"
    },
    "./producer": {
      "types": "./dist/producer.d.ts",
      "import": "./dist/producer.js"
    },
    "./dlq": {
      "types": "./dist/dlq.d.ts",
      "import": "./dist/dlq.js"
    },
    "./metrics": {
      "types": "./dist/metrics.d.ts",
      "import": "./dist/metrics.js"
    },
    "./idempotency": {
      "types": "./dist/idempotency-repository.d.ts",
      "import": "./dist/idempotency-repository.js"
    },
    "./command-utils": {
      "types": "./dist/command-utils.d.ts",
      "import": "./dist/command-utils.js"
    },
    "./cashier": {
      "types": "./dist/cashier.d.ts",
      "import": "./dist/cashier.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths --config-file ../../.swcrc -q && tsc --project tsconfig.json --emitDeclarationOnly",
    "lint": "eslint --ext .ts src",
    "lint:fix": "eslint --ext .ts src --fix",
    "biome": "biome check src",
    "biome:fix": "biome format src --write",
    "knip": "knip --tsConfig tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dlq:replay": "tsx src/cli/dlq-replay.ts"
  },
  "dependencies": {
    "@tartware/config": "workspace:*",
    "@tartware/schemas": "workspace:*",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
