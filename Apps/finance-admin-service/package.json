{
  "name": "@tartware/finance-admin-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix",
    "format": "npx biome check --write src/",
    "biome": "biome check src",
    "biome:fix": "biome format src --write",
    "knip": "knip --tsConfig tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage vitest-report *.tsbuildinfo"
  },
  "dependencies": {
    "@tartware/command-consumer-utils": "workspace:*",
    "@tartware/config": "workspace:*",
    "@tartware/fastify-server": "workspace:*",
    "@tartware/openapi": "workspace:*",
    "@tartware/outbox": "workspace:*",
    "@tartware/schemas": "workspace:*",
    "@tartware/telemetry": "workspace:*",
    "@tartware/tenant-auth": "workspace:*",
    "fastify": "^5.3.3",
    "kafkajs": "^2.2.4",
    "pg": "^8.16.0",
    "pino": "^9.8.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "knip": "^5.62.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
