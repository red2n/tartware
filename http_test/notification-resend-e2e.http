###############################################################################
# NOTIFICATION RESEND E2E - Reservation Created -> Guest Email
# Routes via API Gateway (localhost:8080)
#
# Purpose:
# 1) Create a reservation via command center route
# 2) Allow notification consumer to process reservation.created event
# 3) Verify guest communication records for the guest
#
# Prereqs:
# - notification-service running with:
#   NOTIFICATION_DEFAULT_CHANNEL=resend
#   RESEND_API_KEY=<your_key>
#   RESEND_SENDER_DOMAIN=swaas.tech
#   RESEND_SENDER_EMAIL=noreply@swaas.tech
# - communication template BOOKING_CONFIRMED is active
# - Use a guest that has a valid email address
###############################################################################

@baseUrl = http://localhost:8080
@tenantId = 11111111-1111-1111-1111-111111111111
@propertyId = 22222222-2222-2222-2222-222222222222
@roomTypeId = 44444444-4444-4444-4444-444444444444
@guestId = REPLACE_WITH_GUEST_ID_WITH_EMAIL

###############################################################################
# 1. LOGIN
###############################################################################

# @name login
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "username": "setup.admin",
  "password": "TempPass123"
}

###
@authToken = {{login.response.body.access_token}}

###############################################################################
# 2. (OPTIONAL) FIND A GUEST WITH EMAIL
###############################################################################

###
# Search guest list and pick a guest ID that has email populated
GET {{baseUrl}}/v1/guests?tenant_id={{tenantId}}&limit=50
Authorization: Bearer {{authToken}}

###############################################################################
# 3. CREATE RESERVATION (COMMAND)
###############################################################################

# @name createReservation
POST {{baseUrl}}/v1/commands/reservation.create/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: resend-e2e-res-create-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "guest_id": "{{guestId}}",
    "room_type_id": "{{roomTypeId}}",
    "rate_code": "BAR",
    "check_in_date": "2026-04-20",
    "check_out_date": "2026-04-22",
    "adults": 2,
    "children": 0,
    "source": "DIRECT",
    "channel": "WEB",
    "total_amount": 399.00,
    "currency": "USD",
    "special_requests": "Near elevator"
  }
}

###############################################################################
# 4. CHECK COMMUNICATIONS FOR GUEST
###############################################################################

###
# Run this after a few seconds to allow Kafka consumer processing.
GET {{baseUrl}}/v1/tenants/{{tenantId}}/notifications/guests/{{guestId}}/communications?limit=20&offset=0
Authorization: Bearer {{authToken}}

###############################################################################
# 5. INSPECT A SINGLE COMMUNICATION
###############################################################################

@communicationId = REPLACE_WITH_COMMUNICATION_ID

###
GET {{baseUrl}}/v1/tenants/{{tenantId}}/notifications/communications/{{communicationId}}
Authorization: Bearer {{authToken}}

###############################################################################
# Expected checks for successful Resend path:
# - communication_type is EMAIL
# - status is SENT (or FAILED with provider error details)
# - recipient_email is populated
# - subject/message match BOOKING_CONFIRMED template
###############################################################################
