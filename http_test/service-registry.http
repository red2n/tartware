###############################################################################
# SERVICE REGISTRY - Discovery & Internal Registration
# Read endpoints go through the API Gateway (localhost:8080).
# Internal register/heartbeat/deregister diagnostics are hosted by
# command-center-service on localhost:3035.
###############################################################################

# --- VARIABLES ---
@baseUrl = http://localhost:8080
@commandCenterUrl = http://localhost:3035

###############################################################################
# 1. LOGIN
###############################################################################

# @name login
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "username": "setup.admin",
  "password": "TempPass123"
}

### Extract token
@authToken = {{login.response.body.access_token}}

###############################################################################
# 2. GATEWAY READS
###############################################################################

### List all registered services (via gateway - requires admin auth)
GET {{baseUrl}}/v1/registry/services
Authorization: Bearer {{authToken}}
Content-Type: application/json

###

### Get instances of a specific service (via gateway - requires admin auth)
GET {{baseUrl}}/v1/registry/services/core-service
Authorization: Bearer {{authToken}}
Content-Type: application/json

###############################################################################
# 3. INTERNAL DIAGNOSTICS
# These are service-to-service registry endpoints and are not proxied by the
# gateway. Use them only for local diagnostics.
###############################################################################

### Manually register a service (internal)
POST {{commandCenterUrl}}/v1/registry/register
Content-Type: application/json

{
  "name": "test-service",
  "version": "0.1.0",
  "host": "localhost",
  "port": 9999
}

###

### Send heartbeat (internal)
PUT {{commandCenterUrl}}/v1/registry/heartbeat
Content-Type: application/json

{
  "name": "test-service",
  "port": 9999
}

###

### Deregister a service (internal)
DELETE {{commandCenterUrl}}/v1/registry/deregister
Content-Type: application/json

{
  "name": "test-service",
  "port": 9999
}

###

### Health check (internal - not proxied)
GET {{commandCenterUrl}}/health

###

### Readiness check (internal - not proxied)
GET {{commandCenterUrl}}/ready

###

### Swagger docs (internal - not proxied)
GET {{commandCenterUrl}}/docs
