###############################################################################
# BUILDINGS SERVICE
# Routes via API Gateway (localhost:8080) -> rooms-service (port 3015)
#
# Content: Building CRUD operations
#
# Related files:
# - rooms.http - Rooms & Room Types
# - rates.http - Rate plans and pricing
###############################################################################

# --- VARIABLES ---
@baseUrl = http://localhost:8080
@tenantId = 11111111-1111-1111-1111-111111111111
@propertyId = 22222222-2222-2222-2222-222222222222

###############################################################################
# 1. LOGIN
###############################################################################

# @name login
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "username": "setup.admin",
  "password": "TempPass123"
}

### Extract token
@authToken = {{login.response.body.access_token}}

###############################################################################
# 2. BUILDINGS - LIST
###############################################################################

# List all buildings for property
GET {{baseUrl}}/v1/buildings?tenant_id={{tenantId}}&property_id={{propertyId}}
Authorization: Bearer {{authToken}}

###
# List with pagination
GET {{baseUrl}}/v1/buildings?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=10&offset=0
Authorization: Bearer {{authToken}}

###
# List with search
GET {{baseUrl}}/v1/buildings?tenant_id={{tenantId}}&property_id={{propertyId}}&search=main
Authorization: Bearer {{authToken}}

###
# List by building type
GET {{baseUrl}}/v1/buildings?tenant_id={{tenantId}}&property_id={{propertyId}}&building_type=MAIN_BUILDING
Authorization: Bearer {{authToken}}

###############################################################################
# 3. BUILDINGS - CREATE
###############################################################################

# @name createBuilding
POST {{baseUrl}}/v1/buildings?tenant_id={{tenantId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "property_id": "{{propertyId}}",
  "building_code": "MAIN",
  "building_name": "Main Building",
  "building_type": "MAIN_BUILDING",
  "status": "OPERATIONAL",
  "floor_count": 5,
  "basement_floors": 1,
  "total_rooms": 80,
  "elevator_count": 2,
  "year_built": 2010,
  "wheelchair_accessible": true,
  "has_lobby": true,
  "has_pool": false,
  "has_gym": true,
  "has_spa": false,
  "has_restaurant": true,
  "has_parking": true,
  "parking_spaces": 50,
  "guest_description": "Our flagship main building with modern amenities"
}

### Extract building ID
@buildingId = {{createBuilding.response.body.building_id}}

###
# Create annex building
# @name createAnnex
POST {{baseUrl}}/v1/buildings?tenant_id={{tenantId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "property_id": "{{propertyId}}",
  "building_code": "ANNEX",
  "building_name": "Garden Annex",
  "building_type": "ANNEX",
  "status": "OPERATIONAL",
  "floor_count": 3,
  "total_rooms": 30,
  "elevator_count": 1,
  "year_built": 2018,
  "wheelchair_accessible": true,
  "has_lobby": false,
  "has_pool": true,
  "has_gym": false,
  "has_spa": true,
  "has_restaurant": false,
  "has_parking": false,
  "guest_description": "Quiet garden annex with pool and spa access"
}

###############################################################################
# 4. BUILDINGS - UPDATE
###############################################################################

# Update building details
PUT {{baseUrl}}/v1/buildings/{{buildingId}}?tenant_id={{tenantId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "building_name": "Main Building - Renovated",
  "last_renovation_year": 2024,
  "has_spa": true,
  "guest_description": "Newly renovated main building with full spa facilities"
}

###############################################################################
# 5. BUILDINGS - DELETE (soft delete)
###############################################################################

# Soft delete a building
DELETE {{baseUrl}}/v1/buildings/{{buildingId}}?tenant_id={{tenantId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "tenant_id": "{{tenantId}}"
}
