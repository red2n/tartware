###############################################################################
# AVAILABILITY GUARD SERVICE - Room Locks & Availability Management
# Service-local routes (localhost:3045) because `/v1/locks` is not proxied by
# the API Gateway today.
#
# Content: Room locks for preventing double-booking during reservation flow.
# Auth token comes from the gateway login route. Manual-release and audit
# endpoints also require `x-guard-admin-token`.
###############################################################################

# --- VARIABLES ---
@baseUrl = http://localhost:8080
@availabilityGuardUrl = http://localhost:3045
@tenantId = 11111111-1111-1111-1111-111111111111
@propertyId = 22222222-2222-2222-2222-222222222222
@userId = 33333333-3333-3333-3333-333333333333
@roomTypeId = 44444444-4444-4444-4444-444444444444
@roomId = 55555555-5555-5555-5555-555555555551
@lockId = 66666666-6666-6666-6666-666666666666
@reservationId = 44444444-4444-4444-4444-444444444444
@guardAdminToken = replace-with-availability-guard-admin-token

###############################################################################
# 1. LOGIN
###############################################################################

# @name login
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "username": "setup.admin",
  "password": "TempPass123"
}

### Extract token
@authToken = {{login.response.body.access_token}}

###############################################################################
# 2. CREATE LOCK
# Acquire a temporary lock on a room for a date range
###############################################################################

# @name createLock
POST {{availabilityGuardUrl}}/v1/locks
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "roomTypeId": "{{roomTypeId}}",
  "roomId": "{{roomId}}",
  "stayStart": "2026-03-15T15:00:00.000Z",
  "stayEnd": "2026-03-18T11:00:00.000Z",
  "reason": "RESERVATION_CREATE",
  "correlationId": "booking-session-001",
  "idempotencyKey": "lock-{{$timestamp}}",
  "ttlSeconds": 900,
  "metadata": {
    "sessionId": "booking-session-001",
    "channel": "WEB"
  }
}

### Extract lock ID from response
@newLockId = {{createLock.response.body.lock.id}}

###
# Create lock for maintenance block
POST {{availabilityGuardUrl}}/v1/locks
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "roomTypeId": "{{roomTypeId}}",
  "roomId": "{{roomId}}",
  "stayStart": "2026-04-01T09:00:00.000Z",
  "stayEnd": "2026-04-03T18:00:00.000Z",
  "reason": "MAINTENANCE",
  "correlationId": "maintenance-block-001",
  "ttlSeconds": 86400,
  "metadata": {
    "maintenanceTicket": "MT-2026-001"
  }
}

###
# Create lock for group block
POST {{availabilityGuardUrl}}/v1/locks
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "roomTypeId": "{{roomTypeId}}",
  "roomId": "{{roomId}}",
  "stayStart": "2026-05-10T15:00:00.000Z",
  "stayEnd": "2026-05-15T11:00:00.000Z",
  "reason": "GROUP_BLOCK",
  "correlationId": "group-block-001",
  "ttlSeconds": 604800,
  "metadata": {
    "groupId": "GRP-2026-001",
    "company": "Acme Corp"
  }
}

###############################################################################
# 3. RELEASE LOCK
# Release a specific lock by ID
###############################################################################

### Release lock by ID
DELETE {{availabilityGuardUrl}}/v1/locks/{{newLockId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "reason": "RELEASE_REQUEST",
  "correlationId": "release-{{$timestamp}}",
  "metadata": {
    "source": "http_test"
  }
}

###
# Release known lock with tenant context
DELETE {{availabilityGuardUrl}}/v1/locks/{{lockId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "reason": "RELEASE_REQUEST",
  "correlationId": "release-known-{{$timestamp}}"
}

###############################################################################
# 4. BULK RELEASE LOCKS
# Release multiple locks at once
###############################################################################

### Bulk release by lock IDs
POST {{availabilityGuardUrl}}/v1/locks/bulk-release
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "lockIds": [
    "{{lockId}}",
    "77777777-7777-7777-7777-777777777777",
    "88888888-8888-8888-8888-888888888888"
  ],
  "reason": "BULK_RELEASE",
  "correlationId": "bulk-release-{{$timestamp}}"
}

###############################################################################
# 5. MANUAL RELEASE WITH AUDIT
# Force release a lock with audit trail (requires x-guard-admin-token)
###############################################################################

### Manual release with audit record
POST {{availabilityGuardUrl}}/v1/locks/{{lockId}}/manual-release
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "reason": "Guest cancelled reservation via phone",
  "actorId": "{{userId}}",
  "actorName": "Setup Admin",
  "actorEmail": "setup.admin@tartware.local",
  "correlationId": "manual-release-{{$timestamp}}",
  "metadata": {
    "ticketReference": "TICKET-2026-001"
  },
  "notify": [
    "ops@tartware.local",
    "frontdesk@tartware.local"
  ]
}

###
# Manual release for maintenance cancellation
POST {{availabilityGuardUrl}}/v1/locks/{{lockId}}/manual-release
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "reason": "Maintenance postponed to next month",
  "actorId": "{{userId}}",
  "actorName": "Setup Admin",
  "actorEmail": "setup.admin@tartware.local",
  "correlationId": "manual-release-maint-{{$timestamp}}",
  "metadata": {
    "ticketReference": "MT-2026-001-CANCEL"
  }
}

###############################################################################
# 6. AUDIT RECORDS - BY LOCK ID
# Get audit history for a specific lock
###############################################################################

### Get audit records for a lock
GET {{availabilityGuardUrl}}/v1/locks/{{lockId}}/audit
Authorization: Bearer {{authToken}}
x-guard-admin-token: {{guardAdminToken}}

###
# Get audit records with limit
GET {{availabilityGuardUrl}}/v1/locks/{{lockId}}/audit?limit=10
Authorization: Bearer {{authToken}}
x-guard-admin-token: {{guardAdminToken}}

###############################################################################
# 7. AUDIT RECORDS - TENANT-WIDE SEARCH
# Search audit records across all locks
###############################################################################

### Search all audit records for tenant
GET {{availabilityGuardUrl}}/v1/locks/audit?tenantId={{tenantId}}&limit=50
Authorization: Bearer {{authToken}}
x-guard-admin-token: {{guardAdminToken}}

###
# Filter by explicit lock ID
GET {{availabilityGuardUrl}}/v1/locks/audit?tenantId={{tenantId}}&lockId={{lockId}}
Authorization: Bearer {{authToken}}
x-guard-admin-token: {{guardAdminToken}}

###
# Combined tenant + lock filter with limit
GET {{availabilityGuardUrl}}/v1/locks/audit?tenantId={{tenantId}}&lockId={{lockId}}&limit=10
Authorization: Bearer {{authToken}}
x-guard-admin-token: {{guardAdminToken}}

###############################################################################
# 8. NOTIFICATION TEST (DRY-RUN)
# Test notification delivery classification without releasing the lock
###############################################################################

### Dry-run notification test
POST {{availabilityGuardUrl}}/v1/notifications/manual-release/test
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
x-guard-admin-token: {{guardAdminToken}}

{
  "lockId": "{{lockId}}",
  "tenantId": "{{tenantId}}",
  "reservationId": "{{reservationId}}",
  "roomTypeId": "{{roomTypeId}}",
  "roomId": "{{roomId}}",
  "stayStart": "2026-03-15T15:00:00.000Z",
  "stayEnd": "2026-03-18T11:00:00.000Z",
  "reason": "Manual release notification test",
  "actorId": "{{userId}}",
  "actorName": "Setup Admin",
  "actorEmail": "setup.admin@tartware.local",
  "recipients": [
    "ops@tartware.local",
    "#operations"
  ]
}

###############################################################################
# REFERENCE
###############################################################################
#
# REASONS:
#   RESERVATION_CREATE - Temporary lock during booking flow
#   MAINTENANCE        - Lock for scheduled maintenance
#   GROUP_BLOCK        - Lock for group/event room blocks
#   BULK_RELEASE       - Bulk lock cleanup
#   RELEASE_REQUEST    - Standard release flow
#
# RATE-LIMIT TIERS:
#   Default service tier applies to create/release/bulk-release
#   Admin tier applies to manual-release, audit, and notification test routes
#
# SAMPLE IDS:
#   Tenant:      11111111-1111-1111-1111-111111111111
#   Property:    22222222-2222-2222-2222-222222222222
#   Reservation: 44444444-4444-4444-4444-444444444444
#   Room Type:   44444444-4444-4444-4444-444444444444
#   Room:        55555555-5555-5555-5555-555555555551
#   Lock:        66666666-6666-6666-6666-666666666666
#
###############################################################################
