###############################################################################
# Revenue Service Endpoints
#
# Dynamic pricing engine, competitor rates, demand calendar,
# revenue forecasts, goals, and KPIs.
# Proxied via API Gateway → revenue-service (port 3060).
###############################################################################

@baseUrl = http://localhost:8080
@tenantId = 11111111-1111-1111-1111-111111111111
@propertyId = 22222222-2222-2222-2222-222222222222
@ruleId = aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
@goalId = bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb

# --- Authentication ---
# @name login
POST {{baseUrl}}/v1/auth/login
Content-Type: application/json

{
  "username": "setup.admin",
  "password": "TempPass123"
}

###
@authToken = {{login.response.body.access_token}}

###############################################################################
# DYNAMIC PRICING RULES (S12)
###############################################################################

### List all pricing rules
# @name listPricingRules
GET {{baseUrl}}/v1/revenue/pricing-rules?tenant_id={{tenantId}}&limit=50
Authorization: Bearer {{authToken}}

### List pricing rules for property
# @name listPricingRulesForProperty
GET {{baseUrl}}/v1/revenue/pricing-rules?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=50
Authorization: Bearer {{authToken}}

### List active pricing rules
# @name listActivePricingRules
GET {{baseUrl}}/v1/revenue/pricing-rules?tenant_id={{tenantId}}&is_active=true
Authorization: Bearer {{authToken}}

### Get pricing rule by ID
# @name getPricingRule
GET {{baseUrl}}/v1/revenue/pricing-rules/{{ruleId}}?tenant_id={{tenantId}}
Authorization: Bearer {{authToken}}

###############################################################################
# RATE RECOMMENDATIONS
###############################################################################

### List rate recommendations
# @name listRateRecommendations
GET {{baseUrl}}/v1/revenue/rate-recommendations?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=50
Authorization: Bearer {{authToken}}

###############################################################################
# COMPETITOR RATES
###############################################################################

### List competitor rate intelligence
# @name listCompetitorRates
GET {{baseUrl}}/v1/revenue/competitor-rates?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=50
Authorization: Bearer {{authToken}}

###############################################################################
# DEMAND CALENDAR
###############################################################################

### List demand calendar entries
# @name listDemandCalendar
GET {{baseUrl}}/v1/revenue/demand-calendar?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=50
Authorization: Bearer {{authToken}}

### Demand calendar with date range
# @name listDemandCalendarDateRange
GET {{baseUrl}}/v1/revenue/demand-calendar?tenant_id={{tenantId}}&property_id={{propertyId}}&from_date=2026-03-01&to_date=2026-03-31
Authorization: Bearer {{authToken}}

###############################################################################
# REVENUE FORECASTS (S13)
###############################################################################

### List revenue forecasts
# @name listForecasts
GET {{baseUrl}}/v1/revenue/forecasts?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=50
Authorization: Bearer {{authToken}}

###############################################################################
# REVENUE GOALS
###############################################################################

### List revenue goals with budget vs actual tracking
# @name listRevenueGoals
GET {{baseUrl}}/v1/revenue/goals?tenant_id={{tenantId}}&property_id={{propertyId}}&limit=50
Authorization: Bearer {{authToken}}

###############################################################################
# REVENUE KPIs
###############################################################################

### Get revenue KPIs (occupancy %, ADR, RevPAR)
# @name getRevenueKpis
GET {{baseUrl}}/v1/revenue/kpis?tenant_id={{tenantId}}&property_id={{propertyId}}&business_date=2026-02-12
Authorization: Bearer {{authToken}}

### Get KPIs for a different date
# @name getRevenueKpisAltDate
GET {{baseUrl}}/v1/revenue/kpis?tenant_id={{tenantId}}&property_id={{propertyId}}&business_date=2026-02-11
Authorization: Bearer {{authToken}}

###############################################################################
# COMPSET INDICES (IS-3: STR-style benchmarking)
###############################################################################

### Get competitive set indices (ARI, Occupancy Index, RGI)
# @name getCompsetIndices
GET {{baseUrl}}/v1/revenue/compset-indices?tenant_id={{tenantId}}&property_id={{propertyId}}&business_date=2026-02-13
Authorization: Bearer {{authToken}}

### Get compset indices for previous day
# @name getCompsetIndicesYesterday
GET {{baseUrl}}/v1/revenue/compset-indices?tenant_id={{tenantId}}&property_id={{propertyId}}&business_date=2026-02-12
Authorization: Bearer {{authToken}}

###############################################################################
# PRICING RULE COMMANDS (via Command Center)
###############################################################################

### Create a pricing rule — occupancy-based, 10% increase when occ >= 80%
# @name createPricingRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.create/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: create-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_name": "High Occupancy Surge — 10% increase",
    "rule_type": "occupancy_based",
    "rule_category": "dynamic",
    "description": "Increase rates 10% when occupancy reaches 80% or above",
    "priority": 50,
    "is_active": false,
    "effective_from": "2026-03-15",
    "effective_until": "2026-12-31",
    "conditions": {
      "occupancy_percent": { "operator": ">=", "value": 80 }
    },
    "adjustment_type": "percentage_increase",
    "adjustment_value": 10.00,
    "min_rate": 89.00,
    "max_rate": 499.00,
    "can_combine_with_other_rules": true,
    "requires_approval": false
  }
}

### Create a day-of-week pricing rule — weekend premium
# @name createWeekendRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.create/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: create-weekend-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_name": "Weekend Premium — 15% uplift",
    "rule_type": "day_of_week",
    "rule_category": "yield",
    "description": "Apply 15% premium on Friday and Saturday nights",
    "priority": 60,
    "is_active": false,
    "effective_from": "2026-03-15",
    "applies_monday": false,
    "applies_tuesday": false,
    "applies_wednesday": false,
    "applies_thursday": false,
    "applies_friday": true,
    "applies_saturday": true,
    "applies_sunday": false,
    "conditions": {},
    "adjustment_type": "percentage_increase",
    "adjustment_value": 15.00,
    "adjustment_cap_max": 599.00,
    "can_combine_with_other_rules": true,
    "requires_approval": false
  }
}

### Create a last-minute discount rule
# @name createLastMinuteRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.create/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: create-lastmin-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_name": "Last Minute Discount — 20% off within 48h",
    "rule_type": "last_minute",
    "rule_category": "promotional",
    "description": "Offer 20% discount for bookings made within 48 hours of arrival when occupancy is below 60%",
    "priority": 80,
    "is_active": false,
    "effective_from": "2026-03-15",
    "conditions": {
      "days_until_arrival": { "operator": "<=", "value": 2 },
      "occupancy_percent": { "operator": "<", "value": 60 }
    },
    "adjustment_type": "percentage_decrease",
    "adjustment_value": 20.00,
    "min_rate": 69.00,
    "min_length_of_stay": 1,
    "max_length_of_stay": 3,
    "can_combine_with_other_rules": false,
    "requires_approval": true
  }
}

### Update a pricing rule (change adjustment value and priority)
# @name updatePricingRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.update/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: update-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_id": "{{ruleId}}",
    "adjustment_value": 12.50,
    "priority": 45,
    "last_modified_reason": "Adjusted from 10% to 12.5% based on Q1 performance review"
  }
}

### Activate a pricing rule
# @name activatePricingRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.activate/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: activate-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_id": "{{ruleId}}"
  }
}

### Deactivate a pricing rule
# @name deactivatePricingRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.deactivate/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: deactivate-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_id": "{{ruleId}}"
  }
}

### Delete a pricing rule (soft-delete)
# @name deletePricingRule
POST {{baseUrl}}/v1/commands/revenue.pricing_rule.delete/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: delete-rule-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "rule_id": "{{ruleId}}"
  }
}

###############################################################################
# DEMAND CALENDAR COMMANDS (via Command Center)
###############################################################################

### Update demand levels for specific dates
# @name updateDemandCalendar
POST {{baseUrl}}/v1/commands/revenue.demand.update/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: demand-update-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "dates": ["2026-04-15", "2026-04-16", "2026-04-17"],
    "demand_level": "PEAK",
    "notes": "City Marathon weekend — expect 95%+ occupancy"
  }
}

### Import local market events into demand calendar
# @name importDemandEvents
POST {{baseUrl}}/v1/commands/revenue.demand.import_events/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: demand-events-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "events": [
      {
        "event_name": "Tech Conference 2026",
        "event_type": "convention",
        "start_date": "2026-05-10",
        "end_date": "2026-05-13",
        "impact_multiplier": 1.5,
        "demand_level": "HIGH",
        "notes": "Expected 5000 attendees at convention center"
      },
      {
        "event_name": "Summer Music Festival",
        "event_type": "festival",
        "start_date": "2026-06-20",
        "end_date": "2026-06-22",
        "impact_multiplier": 2.0,
        "demand_level": "PEAK"
      }
    ]
  }
}

###############################################################################
# COMPETITOR RATE COMMANDS (via Command Center)
###############################################################################

### Record a single competitor rate observation
