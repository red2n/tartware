POST {{baseUrl}}/v1/commands/revenue.competitor.record/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: comp-rate-{{$timestamp}}

{
