Authorization: Bearer {{authToken}}

###############################################################################
# DAILY CLOSE — R27 (Night Audit Integration)
###############################################################################

### Run end-of-day revenue processing after night audit
# @name runDailyClose
POST {{baseUrl}}/v1/commands/revenue.daily_close.process/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: daily-close-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "business_date": "2026-03-09"
  }
}

### Daily close — skip forecast recompute (goals only)
# @name runDailyCloseGoalsOnly
POST {{baseUrl}}/v1/commands/revenue.daily_close.process/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: daily-close-goals-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "business_date": "2026-03-09",
    "skip_forecast": true
  }
}

