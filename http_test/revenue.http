        "currency": "USD",
        "includes_breakfast": false
      },
      {
        "competitor_name": "Marriott City Center",
        "room_type_category": "Deluxe Queen",
        "rate_date": "2026-03-15",
        "rate_amount": 175.00,
        "currency": "USD",
        "includes_breakfast": true
      },
      {
        "competitor_name": "Hilton Riverside",
        "room_type_category": "Standard King",
        "rate_date": "2026-03-15",
        "rate_amount": 165.00,
        "currency": "USD",
        "includes_breakfast": false,
        "includes_wifi": true
      }
    ]
  }
}

###############################################################################
# FORECAST COMMAND (via Command Center)
