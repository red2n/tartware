  "payload": {
    "property_id": "{{propertyId}}",
    "competitor_name": "Grand Hyatt Downtown",
    "competitor_property_name": "Grand Hyatt City Center",
    "room_type_category": "Standard King",
    "rate_date": "2026-03-15",
    "rate_amount": 189.00,
    "currency": "USD",
    "source": "booking.com",
    "includes_breakfast": false,
    "includes_wifi": true,
    "taxes_included": false
  }
}

