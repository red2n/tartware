### Compute revenue forecasts
# @name computeForecasts
POST {{baseUrl}}/v1/commands/revenue.forecast.compute/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: forecast-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "forecast_period": "daily",
    "horizon_days": 30,
    "training_days": 90,
    "scenarios": ["base", "optimistic", "pessimistic"]
  }
}

###############################################################################
# RATE RESTRICTIONS — R6 (CTA/CTD/LOS/Closed)
###############################################################################

### List rate restrictions
# @name listRateRestrictions
GET {{baseUrl}}/v1/revenue/rate-restrictions?tenant_id={{tenantId}}&limit=50
Authorization: Bearer {{authToken}}

###

### List rate restrictions with filters
# @name listRateRestrictionsFiltered
GET {{baseUrl}}/v1/revenue/rate-restrictions?tenant_id={{tenantId}}&property_id={{propertyId}}&restriction_type=CTA&date_from=2025-07-01&date_to=2025-07-31&is_active=true&limit=50
Authorization: Bearer {{authToken}}

###

### Set CTA restriction (Closed to Arrival)
# @name setRestrictionCTA
POST {{baseUrl}}/v1/commands/revenue.restriction.set/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: restriction-cta-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "start_date": "2025-07-04",
    "end_date": "2025-07-06",
    "restriction_type": "CTA",
    "restriction_value": 1,
    "is_active": true,
    "source": "manual",
    "reason": "Independence Day weekend — block arrivals to preserve group block"
  }
}

###

### Set Min LOS restriction
# @name setRestrictionMinLOS
POST {{baseUrl}}/v1/commands/revenue.restriction.set/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: restriction-minlos-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "start_date": "2025-12-20",
    "end_date": "2025-12-31",
    "restriction_type": "MIN_LOS",
    "restriction_value": 3,
    "is_active": true,
    "source": "manual",
    "reason": "Holiday season — minimum 3-night stay for all room types"
  }
}

###

### Set CLOSED restriction for a specific rate plan
# @name setRestrictionClosed
POST {{baseUrl}}/v1/commands/revenue.restriction.set/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: restriction-closed-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "start_date": "2025-08-15",
    "end_date": "2025-08-17",
    "restriction_type": "CLOSED",
    "restriction_value": 1,
    "is_active": true,
    "source": "manual",
    "reason": "Convention weekend — close discounted rate codes"
  }
}

###

### Remove a restriction
# @name removeRestriction
POST {{baseUrl}}/v1/commands/revenue.restriction.remove/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: restriction-rm-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "start_date": "2025-07-04",
    "end_date": "2025-07-06",
    "restriction_type": "CTA"
  }
}

###

### Bulk set restrictions (Min LOS 2 for weekends, Max Advance 90 days)
# @name bulkSetRestrictions
POST {{baseUrl}}/v1/commands/revenue.restriction.bulk_set/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: restriction-bulk-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "restrictions": [
      {
        "start_date": "2025-10-01",
        "end_date": "2025-10-31",
        "restriction_type": "MIN_LOS",
        "restriction_value": 2,
        "reason": "Q4 weekends — minimum 2-night stay"
      },
      {
        "start_date": "2025-11-01",
        "end_date": "2025-12-31",
        "restriction_type": "MAX_ADVANCE",
        "restriction_value": 90,
        "reason": "Holiday season — max 90 days advance booking"
      }
    ],
    "is_active": true,
    "source": "manual"
  }
}

###############################################################################
# HURDLE RATES — R7 (Minimum Acceptable Rates)
###############################################################################

### List hurdle rates
# @name listHurdleRates
GET {{baseUrl}}/v1/revenue/hurdle-rates?tenant_id={{tenantId}}&limit=50
Authorization: Bearer {{authToken}}

###

### List hurdle rates with filters
# @name listHurdleRatesFiltered
GET {{baseUrl}}/v1/revenue/hurdle-rates?tenant_id={{tenantId}}&property_id={{propertyId}}&date_from=2025-07-01&date_to=2025-07-31&source=manual&limit=50
Authorization: Bearer {{authToken}}

###

### Set hurdle rate — Standard King for July
# @name setHurdleRate
POST {{baseUrl}}/v1/commands/revenue.hurdle_rate.set/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: hurdle-set-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "room_type_id": "33333333-3333-3333-3333-333333333333",
    "start_date": "2025-07-01",
    "end_date": "2025-07-31",
    "hurdle_rate": 149.99,
    "currency": "USD",
    "segment": "transient",
    "source": "manual",
    "notes": "July floor rate for transient segment — do not sell below"
  }
}

###

### Calculate hurdle rates from displacement analysis
# @name calculateHurdleRates
POST {{baseUrl}}/v1/commands/revenue.hurdle_rate.calculate/execute
Content-Type: application/json
Authorization: Bearer {{authToken}}
X-Request-ID: {{$guid}}
X-Idempotency-Key: hurdle-calc-{{$timestamp}}

{
  "tenant_id": "{{tenantId}}",
  "payload": {
    "property_id": "{{propertyId}}",
    "start_date": "2025-08-01",
    "end_date": "2025-08-31",
    "confidence_threshold": 75
  }
}

