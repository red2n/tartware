###############################################################################
# BUDGET VARIANCE REPORT — R9
###############################################################################

### Get budget variance report (all goals for date range)
# @name getBudgetVarianceReport
GET {{baseUrl}}/v1/revenue/budget-variance?tenant_id={{tenantId}}&property_id={{propertyId}}&from_date=2026-03-01&to_date=2026-03-31
Authorization: Bearer {{authToken}}

### Budget variance filtered by department
# @name getBudgetVarianceDept
GET {{baseUrl}}/v1/revenue/budget-variance?tenant_id={{tenantId}}&property_id={{propertyId}}&from_date=2026-01-01&to_date=2026-03-31&department=rooms
Authorization: Bearer {{authToken}}

### Budget variance filtered by goal type
# @name getBudgetVarianceType
GET {{baseUrl}}/v1/revenue/budget-variance?tenant_id={{tenantId}}&property_id={{propertyId}}&from_date=2026-01-01&to_date=2026-03-31&goal_type=room_revenue
Authorization: Bearer {{authToken}}

