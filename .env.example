# =====================================================
# Tartware PMS - Environment Configuration
# Copy this file to .env and customize as needed
# Trial deployments can rely on built-in service defaults for rate limits,
# outbox timing, Kafka retry schedules, and reliability thresholds.
# Keep only required values active here; uncomment optional overrides only when tuning.
# =====================================================

# =====================================================
# DATABASE INITIALIZATION SETTINGS
# =====================================================

# Drop existing database on startup (⚠️ DELETES ALL DATA)
# Recommended: true for development, false for production
TARTWARE_DROP_EXISTING=true

# Run comprehensive verification after setup
# Recommended: true (ensures database quality)
TARTWARE_RUN_VERIFICATION=true

# Create backup before dropping database
# Recommended: false for dev, true for staging/prod
TARTWARE_BACKUP_BEFORE_DROP=false

# =====================================================
# POSTGRESQL SETTINGS
# =====================================================

# PostgreSQL superuser
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Default database (do not change 'tartware')
POSTGRES_DB=tartware

# Runtime DB password used by services (required outside tests)
DB_PASSWORD=postgres

# =====================================================
# SERVICE LOGGING FLAGS
# =====================================================

# Enable sanitized request/response logs for API gateway
API_GATEWAY_LOG_REQUESTS=false

# Enable sanitized request/response logs for reservations-command-service
RESERVATION_COMMAND_LOG_REQUESTS=false

# Settings service data source (seed | db)
SETTINGS_DATA_SOURCE=seed

# Service Endpoints
CORE_SERVICE_URL=http://localhost:3000
RESERVATION_COMMAND_SERVICE_URL=http://localhost:3101
GUESTS_SERVICE_URL=http://localhost:3300
ROOMS_SERVICE_URL=http://localhost:3400
HOUSEKEEPING_SERVICE_URL=http://localhost:3500
BILLING_SERVICE_URL=http://localhost:3600
COMMAND_CENTER_SERVICE_URL=http://localhost:3700
SETTINGS_SERVICE_URL=http://localhost:3000
COMMAND_CENTER_TOPIC=commands.primary
AUTH_DEFAULT_PASSWORD=TempPass123

# =====================================================
# NOTIFICATION SERVICE (RESEND)
# =====================================================

# Use Resend as the notification provider
NOTIFICATION_DEFAULT_CHANNEL=resend

# Resend API key
RESEND_API_KEY=your_resend_key

# Optional overrides (defaults are already set for this domain)
RESEND_SENDER_DOMAIN=swaas.tech
RESEND_SENDER_EMAIL=noreply@swaas.tech

# =====================================================
# OPTIONAL TRIAL TUNING OVERRIDES
# =====================================================
# Leave these commented for trial deployments unless you need custom tuning.
#
# Reservations command rate limiting
# RESERVATION_COMMAND_RATE_MAX=120
# RESERVATION_COMMAND_RATE_WINDOW=1 minute
# RESERVATION_COMMAND_RATE_READ_MAX=60
# RESERVATION_COMMAND_RATE_READ_WINDOW=1 minute
# RESERVATION_COMMAND_RATE_METRICS_MAX=15
# RESERVATION_COMMAND_RATE_METRICS_WINDOW=1 minute
#
# Reservations command Kafka / outbox / reliability
# RESERVATION_DLQ_TOPIC=reservations.events.dlq
# KAFKA_MAX_RETRIES=3
# KAFKA_RETRY_BACKOFF_MS=1000
# KAFKA_RETRY_SCHEDULE_MS=1000,5000,30000
# KAFKA_MAX_BATCH_BYTES=1048576
# OUTBOX_POLL_INTERVAL_MS=2000
# OUTBOX_BATCH_SIZE=25
# OUTBOX_LOCK_TIMEOUT_MS=30000
# OUTBOX_MAX_RETRIES=5
# OUTBOX_RETRY_BACKOFF_MS=5000
# OUTBOX_TENANT_THROTTLE_MS=0
# OUTBOX_TENANT_JITTER_MS=0
# OUTBOX_TENANT_THROTTLE_CLEANUP_MS=60000
# RELIABILITY_OUTBOX_WARN_THRESHOLD=100
# RELIABILITY_OUTBOX_CRITICAL_THRESHOLD=500
# RELIABILITY_DLQ_WARN_THRESHOLD=10
# RELIABILITY_DLQ_CRITICAL_THRESHOLD=50
# RELIABILITY_STALLED_THRESHOLD_SECONDS=120
# RELIABILITY_CONSUMER_STALE_SECONDS=60
#
# Command Center outbox tuning
# COMMAND_CENTER_CONSUMER_GROUP=reservations-command-center
# COMMAND_CENTER_TARGET_SERVICE_ID=reservations-command-service
# COMMAND_CENTER_OUTBOX_TENANT_THROTTLE_MS=0
# COMMAND_CENTER_OUTBOX_TENANT_JITTER_MS=0
# COMMAND_CENTER_OUTBOX_TENANT_THROTTLE_CLEANUP_MS=60000
#
# Availability guard integration / rate limiting
# AVAILABILITY_GUARD_ENABLED=true
# AVAILABILITY_GUARD_SHADOW_MODE=true
# AVAILABILITY_GUARD_FAIL_OPEN=true
# AVAILABILITY_GUARD_ADDRESS=localhost:4400
# AVAILABILITY_GUARD_TIMEOUT_MS=5000
# AVAILABILITY_GUARD_GRPC_TOKEN=
# AVAILABILITY_GUARD_RATE_MAX=120
# AVAILABILITY_GUARD_RATE_WINDOW=1 minute
# AVAILABILITY_GUARD_RATE_WRITE_MAX=60
# AVAILABILITY_GUARD_RATE_WRITE_WINDOW=1 minute
# AVAILABILITY_GUARD_RATE_ADMIN_MAX=20
# AVAILABILITY_GUARD_RATE_ADMIN_WINDOW=1 minute
# AVAILABILITY_GUARD_MANUAL_RELEASE_ENABLED=true
# AVAILABILITY_GUARD_ADMIN_TOKENS=

# =====================================================
# DEVELOPMENT vs PRODUCTION
# =====================================================

# For DEVELOPMENT (current settings):
# TARTWARE_DROP_EXISTING=true   ← Database recreated each time
# TARTWARE_RUN_VERIFICATION=true
# TARTWARE_BACKUP_BEFORE_DROP=false

# For PRODUCTION (recommended):
# TARTWARE_DROP_EXISTING=false  ← NEVER drop in production
# TARTWARE_RUN_VERIFICATION=true
# TARTWARE_BACKUP_BEFORE_DROP=true

# =====================================================
# NOTES
# =====================================================

# 1. This file should NOT be committed with sensitive data
# 2. Copy to .env and customize: cp .env.example .env
# 3. Add .env to .gitignore
# 4. Use docker-compose.yml to load these variables
